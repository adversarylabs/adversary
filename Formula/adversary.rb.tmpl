class __FORMULA_CLASS__ < Formula
  desc "Run source-code adversaries against a local repository"
  homepage "https://github.com/adversarylabs/adversary"
  version "__VERSION__"
  # No license stanza: upstream has not selected a license. See LICENSE.

  on_macos do
    on_intel do
      url "__DARWIN_AMD64_URL__"
      sha256 "__DARWIN_AMD64_SHA256__"
    end

    on_arm do
      url "__DARWIN_ARM64_URL__"
      sha256 "__DARWIN_ARM64_SHA256__"
    end
  end

  on_linux do
    on_intel do
      url "__LINUX_AMD64_URL__"
      sha256 "__LINUX_AMD64_SHA256__"
    end

    on_arm do
      url "__LINUX_ARM64_URL__"
      sha256 "__LINUX_ARM64_SHA256__"
    end
  end

  def install
    bin.install "adversary" => "__INSTALLED_BINARY__"
  end

  test do
    assert_match version.to_s, shell_output("#{bin}/__INSTALLED_BINARY__ version")
  end
end
