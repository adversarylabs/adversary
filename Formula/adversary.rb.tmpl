class Adversary < Formula
  desc "Run containerized source-code adversaries against a local repository"
  homepage "https://github.com/adversarylabs/adversary"
  version "__VERSION__"

  on_macos do
    on_intel do
      url "__DARWIN_AMD64_URL__"
      sha256 "__DARWIN_AMD64_SHA256__"
    end

    on_arm do
      url "__DARWIN_ARM64_URL__"
      sha256 "__DARWIN_ARM64_SHA256__"
    end
  end

  on_linux do
    on_intel do
      url "__LINUX_AMD64_URL__"
      sha256 "__LINUX_AMD64_SHA256__"
    end

    on_arm do
      url "__LINUX_ARM64_URL__"
      sha256 "__LINUX_ARM64_SHA256__"
    end
  end

  def install
    bin.install "adversary"
  end

  test do
    assert_match "Run containerized source-code adversaries", shell_output("#{bin}/adversary --help")
  end
end
